---
import BaseHead from '../components/BaseHead.astro';
import FlowField from '../components/FlowField.astro';
import FamilyTreeNode from '../components/FamilyTreeNode.astro';
import generatedProjects from '../data/projects.generated.json';
import familyTreeData from '../data/family_tree.json';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

interface ProjectConnection {
	to: string;
	type: 'inspired-by' | 'prototype-for' | 'commissioned' | 'evolved-into' | 'shared-infra';
	note: string;
}

interface ProjectCard {
	name: string;
	ownerRepo: string;
	visibility: 'PUBLIC' | 'PRIVATE';
	slug: string;
	shortDesc: string;
	status: 'Core' | 'Experimental' | 'Commission' | 'Stub';
	threads: string[];
	connections: ProjectConnection[];
	updatedAt: string;
	tag: 'Systems Builder' | 'Applied AI Engineer' | 'Automation + Quality' | 'Developer Experience';
	oneLiner: string;
	impact: string;
	bullets: string[];
	proof: string;
	tech: string[];
	links: {
		publicRepoUrl: string | null;
		requestAccess: boolean;
	};
}

interface FamilyTreeBranch {
	from: string;
	label: string;
	nodes: string[];
}

interface FamilyTreeSpecialNode {
	slug: string;
	noteTop?: string;
	noteBottom?: string;
}

interface FamilyTreeConfig {
	spine: string[];
	branches: FamilyTreeBranch[];
	specialNodes: FamilyTreeSpecialNode[];
}

interface FamilyTreeBranchView {
	id: string;
	label: string;
	nodes: FamilyTreeNodeView[];
}

interface FamilyTreeNodeView {
	project: ProjectCard;
	roleLabel?: string;
	special?: FamilyTreeSpecialNode;
	branches: FamilyTreeBranchView[];
}

const excludedSlugs = new Set(['gauntlet-010', 'gauntlet-005', 'gauntlet001']);
const projects = (generatedProjects as ProjectCard[])
	.filter((project) => !excludedSlugs.has(project.slug))
	.sort((a, b) => a.name.localeCompare(b.name));
const bySlug = new Map(projects.map((project) => [project.slug, project]));

const familyTree = familyTreeData as FamilyTreeConfig;
const branchesByFrom = new Map<string, FamilyTreeBranch[]>();
for (const branch of familyTree.branches) {
	if (!branchesByFrom.has(branch.from)) branchesByFrom.set(branch.from, []);
	branchesByFrom.get(branch.from)?.push(branch);
}
const specialBySlug = new Map(familyTree.specialNodes.map((node) => [node.slug, node]));

const spineRoleLabels = ['Origin', 'Turning Point', 'Next Gen'];
const usedTreeSlugs = new Set<string>();

function toIdPart(value: string): string {
	return value.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
}

function makeBranchId(fromSlug: string, label: string): string {
	return `branch-${toIdPart(fromSlug)}-${toIdPart(label)}`;
}

function buildTreeNode(slug: string, roleLabel?: string): FamilyTreeNodeView | null {
	if (usedTreeSlugs.has(slug)) return null;
	const project = bySlug.get(slug);
	if (!project) return null;

	usedTreeSlugs.add(slug);

	const branchGroups = (branchesByFrom.get(slug) || [])
		.map((branch) => {
			const nodes = branch.nodes
				.map((childSlug) => buildTreeNode(childSlug))
				.filter((node): node is FamilyTreeNodeView => Boolean(node));
			if (nodes.length === 0) return null;
			return {
				id: makeBranchId(slug, branch.label),
				label: branch.label,
				nodes,
			};
		})
		.filter((group): group is FamilyTreeBranchView => Boolean(group));

	return {
		project,
		roleLabel,
		special: specialBySlug.get(slug),
		branches: branchGroups,
	};
}

const spineNodes = familyTree.spine
	.map((slug, index) => buildTreeNode(slug, spineRoleLabels[index] || 'Stage'))
	.filter((node): node is FamilyTreeNodeView => Boolean(node));

if (spineNodes.length > 0) {
	const unplacedNodes = projects
		.filter((project) => !usedTreeSlugs.has(project.slug))
		.map((project) => buildTreeNode(project.slug))
		.filter((node): node is FamilyTreeNodeView => Boolean(node));

	if (unplacedNodes.length > 0) {
		spineNodes[spineNodes.length - 1].branches.push({
			id: makeBranchId(spineNodes[spineNodes.length - 1].project.slug, 'Additional explorations'),
			label: 'Additional explorations',
			nodes: unplacedNodes,
		});
	}
}

const aiFocusOrder = ['friday', 'muninn', 'laila', 'lex'];
const aiPlatformProjects = aiFocusOrder
	.map((slug) => bySlug.get(slug))
	.filter((project): project is ProjectCard => Boolean(project))
	.slice(0, 5);

const statusOrder: ProjectCard['status'][] = ['Core', 'Experimental', 'Commission', 'Stub'];
const groupedByStatus = statusOrder
	.map((status) => ({
		status,
		items: projects.filter((project) => project.status === status),
	}))
	.filter((group) => group.items.length > 0);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<div class="page-shell">
			<header class="main-nav">
				<nav class="container nav-inner" aria-label="Primary">
					<a href="#hero" class="brand">austontatious.dev</a>
					<div class="nav-links">
						<a href="#snapshot">Snapshot</a>
						<a href="#progression">Progression</a>
						<a href="#projects">Projects</a>
					</div>
					<div class="nav-actions">
						<a href="mailto:auston.horras@gmail.com">Email</a>
						<a href="https://www.linkedin.com/in/auston-horras-17022614/" target="_blank" rel="noreferrer">
							LinkedIn
						</a>
					</div>
				</nav>
			</header>

			<main>
				<section id="hero" class="section hero">
					<FlowField variant="hero" />
					<div class="container section-inner">
						<p class="eyebrow">Calm systems for high-stakes decisions</p>
						<h1>AI Architect.</h1>
						<p class="lead">Calm inside complexity.</p>
						<p class="support">I build AI systems that turn uncertainty into clear outcomes.</p>
						<p class="workshop-note">
							I also offer practical generative AI workshops for teams, focused on how to actually work with
							AI in real-world workflows.
						</p>
						<a class="workshop-link" href="/workshops/">Practical AI Workshops</a>
					</div>
				</section>

				<section id="snapshot" class="section">
					<div class="container section-inner">
						<h2>Professional Snapshot</h2>
						<p class="snapshot-title">
							Senior Systems &amp; Applied AI Engineer building reliable automation, local-first AI platforms,
							and production-minded developer tooling.
						</p>
						<div class="capability-grid">
							<article class="capability-panel">
								<h3>Systems Engineering</h3>
								<ul>
									<li>Distributed services</li>
									<li>Docker &amp; orchestration</li>
									<li>API-driven architecture</li>
									<li>Reliability-focused automation</li>
									<li>CI-friendly testing</li>
								</ul>
							</article>
							<article class="capability-panel">
								<h3>Applied AI Engineering</h3>
								<ul>
									<li>Agent systems</li>
									<li>Memory architecture</li>
									<li>Computer vision pipelines</li>
									<li>GPU workflows</li>
									<li>Evaluation + quality loops</li>
								</ul>
							</article>
							<article class="capability-panel">
								<h3>Developer Enablement</h3>
								<ul>
									<li>Dev tooling</li>
									<li>Reproducible environments</li>
									<li>Automation scripts</li>
									<li>Workflow design</li>
									<li>Operator-safe deployments</li>
								</ul>
							</article>
						</div>
						<p class="core-tech">
							<span>Core Technologies:</span> Python • FastAPI • Docker • Linux • CUDA • PyTest • TypeScript • React • Node.js • Nginx • GitHub Actions • REST APIs • AI Agents • Computer Vision • LLM Integration
						</p>
						<p class="micro-signal">
							Open to senior-level engineering roles involving systems architecture, AI infrastructure, or
							developer productivity platforms.
						</p>
					</div>
				</section>

				<section id="progression" class="section">
					<FlowField variant="echo" />
					<div class="container section-inner">
						<h2>Not isolated tools. A connected system.</h2>
						<p class="progression-helper">If you only read one thing: this is the project family tree.</p>
						<div class="family-tree-shell">
							<ul class="family-spine-list" id="family-spine">
								{spineNodes.map((node) => <FamilyTreeNode node={node} depth={0} />)}
							</ul>
						</div>
					</div>
				</section>

				<section id="ai-focus" class="section">
					<div class="container section-inner">
						<h2>AI Platform Focus</h2>
						<p class="ai-focus-copy">
							FRIDAY began as local coding-agent orchestration. Muninn emerged when memory moved from embedded
							feature to standalone infrastructure. LAILA now carries that spine into the next generation of
							identity-aware runtime behavior.
						</p>
						<ul class="ai-focus-links">
							{aiPlatformProjects.map((project) => <li><a href={`/projects/${project.slug}/`}>{project.name}</a></li>)}
						</ul>
					</div>
				</section>

				<section id="projects" class="section">
					<div class="container section-inner">
						<h2>Projects Index</h2>
						<nav class="fast-scan" aria-label="Selected project fast-scan">
							<a href="#spine-friday">Agent Platform</a>
							<a href="#branch-friday-experimentation-waves">Applied AI</a>
							<a href="#branch-friday-commission-work-applied-competencies">Systems / Automation</a>
						</nav>

						{
							groupedByStatus.map((group) => (
								<section class="status-group" id={`status-${group.status.toLowerCase()}`}>
									<h3>{group.status}</h3>
									<div class="projects-index-list">
										{
											group.items.map((project) => (
												<article class="project-row">
													<div class="project-row-head">
														<a class="project-row-name" href={`/projects/${project.slug}/`}>{project.name}</a>
														<div class="project-row-badges">
															<span class="badge">{project.tag}</span>
															<span class="badge">{project.status}</span>
															{project.links.requestAccess && <span class="badge">Access on request</span>}
														</div>
													</div>
													<p class="project-row-desc">{project.shortDesc}</p>
													<div class="project-row-meta">
														<span>Updated: {project.updatedAt.slice(0, 7)}</span>
														{project.links.publicRepoUrl && (
															<a href={project.links.publicRepoUrl} target="_blank" rel="noreferrer">GitHub</a>
														)}
													</div>
												</article>
											))
										}
									</div>
								</section>
							))
						}
					</div>
				</section>
			</main>

			<footer class="site-footer">
				<div class="container footer-inner">
					<p>Calm systems for clear outcomes.</p>
					<div class="footer-links">
						<a href="mailto:auston.horras@gmail.com">Contact</a>
						<a href="https://www.linkedin.com/in/auston-horras-17022614/" target="_blank" rel="noreferrer">LinkedIn</a>
						<a href="https://github.com/austontatious" target="_blank" rel="noreferrer">GitHub</a>
					</div>
				</div>
			</footer>
		</div>
	</body>
</html>
