---
import BaseHead from '../components/BaseHead.astro';

const MIMIR_TITLE = 'Mímir | austontatious.dev';
const MIMIR_DESCRIPTION = 'A persistent memory and navigation layer for AI systems working inside real codebases.';

const valueChips = ['Persistent structure', 'Stable references', 'Relationship-aware context'];

const failureSymptoms = [
	'redundant search',
	'shallow retrieval',
	'brittle edits',
	'confused scope',
	'repeated reorientation cost',
];

const capabilityCards = [
	{
		title: 'Cards',
		copy: 'Capture durable repository meaning so the system is working with normalized understanding, not loose snippets.',
	},
	{
		title: 'Bindings',
		copy: 'Preserve attachment to real code locations as paths move, names change, and local structure shifts.',
	},
	{
		title: 'Signals',
		copy: 'Separate meaningful change from churn so memory quality improves instead of accumulating noise.',
	},
	{
		title: 'Adjacencies',
		copy: 'Expose structural relationships so retrieval follows the system topology rather than surface similarity alone.',
	},
];

const builtItems = [
	'ingestion pipeline in place',
	'stable bindings implemented',
	'signals and evidence model in place',
	'adjacency population implemented',
	'repair and remap workflows implemented',
];

const scopeItems = [
	'semantic layer intentionally deferred',
	'current value is structure plus rehydration',
	'designed for evolving repos, not static snapshots',
	'aimed at agent navigation, not just retrieval demos',
];

const outcomeCards = [
	{
		title: 'Lower token waste',
		copy: 'Less context budget spent reconstructing orientation before useful work begins.',
	},
	{
		title: 'Better first-target selection',
		copy: 'Agents get pointed at the right subsystem, file, and symbol earlier in the task.',
	},
	{
		title: 'Higher trust in repo-scale work',
		copy: 'Fewer brittle edits and fewer failures caused by losing the surrounding system context.',
	},
];

const audienceCards = [
	{
		title: 'Technical cofounders',
		copy: 'People who immediately see structural memory as missing infrastructure for AI software systems.',
	},
	{
		title: 'Devtools / infra operators',
		copy: 'Teams that know how to harden a sharp technical system and position it as foundational tooling.',
	},
	{
		title: 'Engineering leaders',
		copy: 'Builders who feel the cost of repeated reorientation in large, fast-moving repositories.',
	},
	{
		title: 'Strategic partners / investors',
		copy: 'People who recognize where persistent codebase intelligence could sit in the stack if built correctly.',
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={MIMIR_TITLE} description={MIMIR_DESCRIPTION} image="/images/mimir/mimir-search-vs-navigation.png" />
		<style>
			:root {
				--mimir-border: rgba(255, 255, 255, 0.12);
				--mimir-border-soft: rgba(255, 255, 255, 0.08);
				--mimir-border-strong: rgba(58, 110, 255, 0.34);
				--mimir-text: var(--text);
				--mimir-text-strong: #f4f7ff;
				--mimir-muted: rgba(233, 238, 255, 0.76);
				--mimir-muted-strong: rgba(233, 238, 255, 0.86);
				--mimir-accent: var(--g1);
				--mimir-accent-soft: rgba(58, 110, 255, 0.12);
				--mimir-panel-bg: linear-gradient(180deg, rgba(18, 26, 46, 0.74), rgba(15, 21, 37, 0.86));
				--mimir-panel-bg-soft: linear-gradient(180deg, rgba(12, 18, 32, 0.58), rgba(12, 18, 32, 0.76));
				--mimir-panel-bg-strong: linear-gradient(180deg, rgba(18, 26, 46, 0.82), rgba(15, 21, 37, 0.92));
				--mimir-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04);
			}

			body.mimir-page-body {
				background:
					radial-gradient(circle at 78% -12%, rgba(58, 110, 255, 0.14) 0%, rgba(10, 15, 28, 0) 40%),
					radial-gradient(circle at 14% 120%, rgba(124, 58, 237, 0.1) 0%, rgba(5, 7, 13, 0) 45%),
					linear-gradient(180deg, var(--bg1) 0%, var(--bg0) 50%, var(--bg1) 100%);
				color: var(--mimir-text);
			}

			.mimir-page {
				color: var(--mimir-text);
			}

			.mimir-page .container {
				width: min(1120px, calc(100% - 3rem));
			}

			.mimir-page h1,
			.mimir-page h2,
			.mimir-page h3 {
				color: var(--mimir-text-strong);
			}

			.mimir-page p {
				color: var(--mimir-muted);
			}

			.mimir-main {
				padding-bottom: 2rem;
			}

			.mimir-section {
				padding: clamp(3.6rem, 7vw, 5.75rem) 0;
				border-top: 1px solid var(--line);
			}

			.mimir-hero {
				border-top: 0;
				padding-top: clamp(2.8rem, 6vw, 4.75rem);
			}

			.mimir-back-link {
				display: inline-flex;
				align-items: center;
				gap: 0.4rem;
				margin-bottom: 1.15rem;
				font-size: 0.82rem;
				letter-spacing: 0.06em;
				text-decoration: none;
				color: rgba(233, 238, 255, 0.72);
				transition: color 180ms ease;
			}

			.mimir-back-link:hover {
				color: #fff;
			}

			.mimir-hero-grid,
			.mimir-problem-grid {
				display: grid;
				grid-template-columns: minmax(0, 1fr) minmax(340px, 0.96fr);
				gap: clamp(1.4rem, 3vw, 3rem);
				align-items: start;
			}

			.mimir-eyebrow {
				margin: 0;
				font-size: 0.78rem;
				font-weight: 700;
				letter-spacing: 0.16em;
				text-transform: uppercase;
				color: rgba(233, 238, 255, 0.72);
			}

			.mimir-page h1 {
				margin-top: 0.7rem;
				font-size: clamp(3.15rem, 8vw, 5.9rem);
				font-weight: 700;
				letter-spacing: -0.05em;
			}

			.mimir-hero-subhead {
				margin-top: 0.9rem;
				max-width: 18ch;
				font-size: clamp(1.45rem, 3vw, 2.2rem);
				line-height: 1.12;
				color: var(--mimir-text-strong);
			}

			.mimir-hero-support {
				margin-top: 1rem;
				max-width: 40ch;
				font-size: 1.03rem;
				line-height: 1.58;
				color: var(--mimir-muted);
			}

			.mimir-cta-row {
				display: flex;
				flex-wrap: wrap;
				gap: 0.75rem;
				margin-top: 1.35rem;
			}

			.mimir-cta-row .button-primary {
				box-shadow: 0 14px 30px rgba(58, 110, 255, 0.2);
			}

			.mimir-value-strip {
				display: grid;
				grid-template-columns: repeat(3, minmax(0, 1fr));
				gap: 0.75rem;
				margin-top: 1.45rem;
			}

			.mimir-chip {
				display: flex;
				align-items: center;
				gap: 0.68rem;
				padding: 0.88rem 1rem;
				border-radius: 1rem;
				border: 1px solid var(--mimir-border);
				background: var(--mimir-panel-bg-soft);
				font-size: 0.93rem;
				font-weight: 600;
				color: var(--mimir-text-strong);
				box-shadow: var(--mimir-shadow);
			}

			.mimir-chip::before {
				content: '';
				width: 0.62rem;
				height: 0.62rem;
				border-radius: 999px;
				background: var(--mimir-accent);
				box-shadow: 0 0 0 5px rgba(58, 110, 255, 0.14);
				flex: 0 0 auto;
			}

			.mimir-section-heading {
				max-width: 43rem;
			}

			.mimir-section-heading h2 {
				font-size: clamp(1.85rem, 4vw, 3rem);
				font-weight: 650;
				letter-spacing: -0.04em;
			}

			.mimir-section-heading p {
				margin-top: 0.8rem;
				max-width: 44rem;
				font-size: 1rem;
				line-height: 1.62;
				color: var(--mimir-muted);
			}

			.mimir-copy-panel,
			.mimir-problem-panel,
			.mimir-proof-shell,
			.mimir-audience-card,
			.mimir-capability-card,
			.mimir-outcome-card,
			.mimir-closing-shell {
				border: 1px solid var(--mimir-border);
				border-radius: 1.3rem;
				background: var(--mimir-panel-bg);
				box-shadow: var(--mimir-shadow);
			}

			.mimir-copy-panel,
			.mimir-problem-panel,
			.mimir-proof-shell,
			.mimir-closing-shell {
				padding: clamp(1.2rem, 2.8vw, 1.75rem);
			}

			.mimir-copy-panel h2 {
				font-size: clamp(1.75rem, 3vw, 2.45rem);
				letter-spacing: -0.04em;
			}

			.mimir-copy-panel p {
				margin-top: 0.85rem;
				max-width: 36ch;
				font-size: 1rem;
				line-height: 1.62;
				color: var(--mimir-muted);
			}

			.mimir-meta-label {
				margin: 0;
				font-size: 0.76rem;
				font-weight: 700;
				letter-spacing: 0.16em;
				text-transform: uppercase;
				color: rgba(233, 238, 255, 0.68);
			}

			.mimir-symptom-list,
			.mimir-proof-list {
				margin: 0;
				padding: 0;
				list-style: none;
			}

			.mimir-symptom-list {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 0.6rem;
				margin-top: 0.9rem;
			}

			.mimir-symptom-list li {
				padding: 0.72rem 0.78rem;
				border-radius: 0.9rem;
				border: 1px solid var(--mimir-border-soft);
				background: var(--mimir-panel-bg-soft);
				font-size: 0.89rem;
				font-weight: 600;
				color: var(--mimir-text-strong);
			}

			.mimir-figure {
				margin: 0;
			}

			.mimir-figure-frame {
				overflow: hidden;
				border-radius: 1.35rem;
				border: 1px solid var(--mimir-border);
				background: rgba(9, 13, 23, 0.72);
				box-shadow: var(--mimir-shadow);
			}

			.mimir-figure-frame img {
				display: block;
				width: 100%;
				height: auto;
			}

			.mimir-figure figcaption {
				margin-top: 0.72rem;
				font-size: 0.88rem;
				line-height: 1.52;
				color: rgba(233, 238, 255, 0.72);
			}

			.mimir-figure figcaption strong {
				display: block;
				margin-bottom: 0.14rem;
				font-size: 0.75rem;
				font-weight: 700;
				letter-spacing: 0.14em;
				text-transform: uppercase;
				color: rgba(233, 238, 255, 0.58);
			}

			.mimir-hero-figure {
				align-self: stretch;
			}

			.mimir-problem-panel .mimir-figure {
				margin-top: 1rem;
			}

			.mimir-diagram-stack {
				margin-top: 1.35rem;
			}

			.mimir-inline-callout {
				display: inline-flex;
				align-items: center;
				margin-top: 1rem;
				padding: 0.6rem 0.85rem;
				border-radius: 999px;
				border: 1px solid var(--mimir-border-strong);
				background: var(--mimir-accent-soft);
				font-size: 0.88rem;
				font-weight: 600;
				color: rgba(214, 230, 255, 0.96);
			}

			.mimir-capability-grid,
			.mimir-outcome-grid,
			.mimir-audience-grid {
				display: grid;
				gap: 0.85rem;
				margin-top: 1.3rem;
			}

			.mimir-capability-grid {
				grid-template-columns: repeat(4, minmax(0, 1fr));
			}

			.mimir-outcome-grid {
				grid-template-columns: repeat(3, minmax(0, 1fr));
			}

			.mimir-audience-grid {
				grid-template-columns: repeat(2, minmax(0, 1fr));
			}

			.mimir-capability-card,
			.mimir-outcome-card,
			.mimir-audience-card {
				padding: 1rem 1.05rem;
				transition:
					transform 180ms ease,
					border-color 180ms ease,
					background 180ms ease;
			}

			.mimir-capability-card:hover,
			.mimir-outcome-card:hover,
			.mimir-audience-card:hover {
				transform: translateY(-2px);
				border-color: var(--mimir-border-strong);
				background: linear-gradient(180deg, rgba(22, 31, 56, 0.88), rgba(15, 21, 37, 0.94));
			}

			.mimir-capability-card h3,
			.mimir-outcome-card h3,
			.mimir-audience-card h3 {
				font-size: 1rem;
				font-weight: 650;
				letter-spacing: -0.02em;
			}

			.mimir-capability-card p,
			.mimir-outcome-card p,
			.mimir-audience-card p {
				margin-top: 0.52rem;
				font-size: 0.94rem;
				line-height: 1.55;
				color: var(--mimir-muted);
			}

			.mimir-proof-grid {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 0.9rem;
				margin-top: 1.2rem;
			}

			.mimir-proof-column {
				padding: 1rem 1.05rem;
				border-radius: 1rem;
				border: 1px solid var(--mimir-border-soft);
				background: var(--mimir-panel-bg-soft);
			}

			.mimir-proof-column h3 {
				font-size: 0.8rem;
				font-weight: 700;
				letter-spacing: 0.14em;
				text-transform: uppercase;
				color: rgba(233, 238, 255, 0.68);
			}

			.mimir-proof-list {
				display: grid;
				gap: 0.7rem;
				margin-top: 0.85rem;
			}

			.mimir-proof-list li {
				position: relative;
				padding-left: 1rem;
				font-size: 0.95rem;
				line-height: 1.52;
				color: var(--mimir-muted-strong);
			}

			.mimir-proof-list li::before {
				content: '';
				position: absolute;
				left: 0;
				top: 0.54rem;
				width: 0.42rem;
				height: 0.42rem;
				border-radius: 999px;
				background: var(--mimir-accent);
			}

			.mimir-proof-note {
				margin-top: 1rem;
				font-size: 0.88rem;
				color: rgba(233, 238, 255, 0.72);
			}

			.mimir-closing-shell {
				display: grid;
				gap: 0.9rem;
				border-color: var(--mimir-border-strong);
				background: linear-gradient(180deg, rgba(21, 31, 56, 0.94), rgba(15, 21, 37, 0.96));
			}

			.mimir-closing-shell h2 {
				font-size: clamp(1.9rem, 4vw, 2.9rem);
				letter-spacing: -0.04em;
			}

			.mimir-closing-shell p {
				max-width: 42rem;
				font-size: 1rem;
				line-height: 1.62;
				color: var(--mimir-muted-strong);
			}

			.mimir-contact-line {
				font-size: 0.9rem;
				color: rgba(233, 238, 255, 0.72);
			}

			.mimir-contact-line a {
				color: var(--mimir-text-strong);
				text-decoration: none;
			}

			.mimir-contact-line a:hover {
				color: #fff;
			}

			@media (max-width: 960px) {
				.mimir-hero-grid,
				.mimir-problem-grid,
				.mimir-capability-grid,
				.mimir-proof-grid,
				.mimir-outcome-grid,
				.mimir-audience-grid {
					grid-template-columns: 1fr;
				}

				.mimir-value-strip {
					grid-template-columns: 1fr;
				}

				.mimir-symptom-list {
					grid-template-columns: 1fr;
				}
			}

			@media (max-width: 720px) {
				.mimir-page .container {
					width: min(1120px, calc(100% - 2rem));
				}

				.mimir-hero {
					padding-top: 2.2rem;
				}

				.mimir-cta-row .button {
					width: 100%;
				}
			}
		</style>
	</head>
	<body class="mimir-page-body">
		<div class="page-shell mimir-page">
			<header class="main-nav">
				<nav class="container nav-inner" aria-label="Primary">
					<a href="/" class="brand">austontatious.dev</a>
					<div class="nav-links nav-links-primary">
						<a href="/">Home</a>
						<a href="/workshops/">Workshops</a>
						<a href="/Mimir" aria-current="page">Mímir</a>
						<a href="https://github.com/austontatious" target="_blank" rel="noreferrer">GitHub</a>
						<a href="mailto:auston.horras@gmail.com">Contact</a>
					</div>
				</nav>
			</header>

			<main class="mimir-main">
				<section class="mimir-section mimir-hero">
					<div class="container">
						<a class="mimir-back-link" href="/">Return to home</a>
						<div class="mimir-hero-grid">
							<div class="mimir-hero-copy">
								<p class="mimir-eyebrow">Codebase Intelligence Infrastructure</p>
								<h1>Mímir</h1>
								<p class="mimir-hero-subhead">A persistent memory and navigation layer for AI systems working inside real codebases.</p>
								<p class="mimir-hero-support">
									Most AI coding systems still behave like first-time visitors in unfamiliar repositories. Mímir gives them durable orientation so context can be navigated instead of reconstructed.
								</p>
								<div class="mimir-cta-row">
									<a class="button button-primary" href="mailto:auston.horras@gmail.com?subject=M%C3%ADmir%20conversation">Start a conversation</a>
									<a class="button button-secondary" href="https://github.com/austontatious" target="_blank" rel="noreferrer">View GitHub</a>
								</div>
							</div>
							<figure class="mimir-figure mimir-hero-figure">
								<div class="mimir-figure-frame">
									<img src="/images/mimir/mimir-search-vs-navigation.png" alt="Search-style retrieval contrasted with structure-aware codebase navigation." loading="eager" />
								</div>
								<figcaption>
									<strong>Featured diagram</strong>
									Search-style retrieval versus structure-aware navigation inside a real repository.
								</figcaption>
							</figure>
						</div>
						<div class="mimir-value-strip">
							{valueChips.map((chip) => (
								<div class="mimir-chip">{chip}</div>
							))}
						</div>
					</div>
				</section>

				<section class="mimir-section">
					<div class="container">
						<div class="mimir-problem-grid">
							<div class="mimir-copy-panel">
								<p class="mimir-eyebrow">The Problem</p>
								<h2>AI coding tools keep re-solving orientation from scratch.</h2>
								<p>
									Search, reranking, and larger context windows can help, but they still ask the model to reconstruct where it is before it can act safely. That makes repository-scale work slower, noisier, and less trustworthy than it looks in a demo.
								</p>
							</div>
							<div class="mimir-problem-panel">
								<p class="mimir-meta-label">Failure symptoms</p>
								<ul class="mimir-symptom-list">
									{failureSymptoms.map((symptom) => (
										<li>{symptom}</li>
									))}
								</ul>
								<figure class="mimir-figure">
									<div class="mimir-figure-frame">
										<img src="/images/mimir/traditional-rag-context-window.png" alt="Traditional RAG workflow showing retrieval and context windows overloaded with reconstruction work." loading="lazy" />
									</div>
									<figcaption>
										<strong>Where the stack bends</strong>
										Traditional RAG pushes orientation work into retrieval and the context window instead of solving it structurally first.
									</figcaption>
								</figure>
							</div>
						</div>
					</div>
				</section>

				<section class="mimir-section">
					<div class="container">
						<div class="mimir-section-heading">
							<p class="mimir-eyebrow">What Mímir Changes</p>
							<h2>Mímir is a structural layer, not a search feature.</h2>
							<p>
								It maintains durable repository orientation, then serves the smallest useful bundle of code and context for the task at hand. The goal is not more text in the window. The goal is less guesswork before reasoning starts.
							</p>
						</div>
						<div class="mimir-diagram-stack">
							<figure class="mimir-figure">
								<div class="mimir-figure-frame">
									<img src="/images/mimir/mimir-structured-map-to-context.png" alt="Structured map approach that narrows from subsystem to file to symbol before assembling working context." loading="lazy" />
								</div>
								<figcaption>
									<strong>Navigation model</strong>
									Rehydration narrows from subsystem to file to symbol to exact working span instead of dumping large source fragments into context.
								</figcaption>
							</figure>
						</div>
						<p class="mimir-inline-callout">Mímir is a GPS for a codebase, not a search engine.</p>
						<div class="mimir-capability-grid">
							{capabilityCards.map((card) => (
								<article class="mimir-capability-card">
									<h3>{card.title}</h3>
									<p>{card.copy}</p>
								</article>
							))}
						</div>
					</div>
				</section>

				<section class="mimir-section">
					<div class="container">
						<div class="mimir-proof-shell">
							<div class="mimir-section-heading">
								<p class="mimir-eyebrow">Built Already, Not Hypothetical</p>
								<h2>Current implementation status</h2>
								<p>
									The project is already useful at the structure and rehydration layer. What remains is hardening, expansion, and disciplined productization, not proving the category should exist.
								</p>
							</div>
							<div class="mimir-proof-grid">
								<div class="mimir-proof-column">
									<h3>In place now</h3>
									<ul class="mimir-proof-list">
										{builtItems.map((item) => (
											<li>{item}</li>
										))}
									</ul>
								</div>
								<div class="mimir-proof-column">
									<h3>Current scope</h3>
									<ul class="mimir-proof-list">
										{scopeItems.map((item) => (
											<li>{item}</li>
										))}
									</ul>
								</div>
							</div>
							<p class="mimir-proof-note">Current direction: relationship-aware rehydration bundles before heavier semantic expansion.</p>
						</div>
					</div>
				</section>

				<section class="mimir-section">
					<div class="container">
						<div class="mimir-section-heading">
							<p class="mimir-eyebrow">Why This Matters</p>
							<h2>Repository-scale reliability needs orientation, not just recall.</h2>
							<p>
