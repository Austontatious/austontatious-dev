---
import BaseHead from '../components/BaseHead.astro';
import FlowField from '../components/FlowField.astro';
import FamilyTreeNode from '../components/FamilyTreeNode.astro';
import generatedProjects from '../data/projects.generated.json';
import familyTreeData from '../data/family_tree.json';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

interface ProjectConnection {
	to: string;
	type: 'inspired-by' | 'prototype-for' | 'commissioned' | 'evolved-into' | 'shared-infra';
	note: string;
}

interface ProjectCard {
	name: string;
	ownerRepo: string;
	visibility: 'PUBLIC' | 'PRIVATE';
	slug: string;
	shortDesc: string;
	status: 'Core' | 'Experimental' | 'Commission' | 'Stub';
	threads: string[];
	connections: ProjectConnection[];
	updatedAt: string;
	tag: 'Systems Builder' | 'Applied AI Engineer' | 'Automation + Quality' | 'Developer Experience';
	oneLiner: string;
	impact: string;
	bullets: string[];
	proof: string;
	tech: string[];
	links: {
		publicRepoUrl: string | null;
		requestAccess: boolean;
	};
}

interface FamilyTreeBranch {
	from: string;
	label: string;
	nodes: string[];
}

interface FamilyTreeSpecialNode {
	slug: string;
	noteTop?: string;
	noteBottom?: string;
}

interface FamilyTreeConfig {
	spine: string[];
	branches: FamilyTreeBranch[];
	specialNodes: FamilyTreeSpecialNode[];
}

interface FamilyTreeBranchView {
	id: string;
	label: string;
	nodes: FamilyTreeNodeView[];
}

interface FamilyTreeNodeView {
	project: HomeProjectCard;
	roleLabel?: string;
	special?: FamilyTreeSpecialNode;
	branches: FamilyTreeBranchView[];
}

interface FeaturedPath {
	title: string;
	description: string;
	bullets?: string[];
	href: string;
	cta: string;
}

interface HomeProjectCard {
	name: string;
	slug: string;
	shortDesc: string;
	status: 'Core' | 'Experimental' | 'Commission' | 'Stub';
	tag: 'Systems Builder' | 'Applied AI Engineer' | 'Automation + Quality' | 'Developer Experience';
	updatedAt: string;
	links: {
		publicRepoUrl: string | null;
		requestAccess: boolean;
	};
	href?: string;
}

const mimirProjectCard: HomeProjectCard = {
	name: 'Mímir',
	slug: 'mimir',
	href: '/Mimir',
	tag: 'Applied AI Engineer',
	status: 'Core',
	shortDesc:
		'Codebase topology and structural memory layer for AI systems, designed to preserve attachment, navigate repositories, and rehydrate the right working context across change.',
	updatedAt: '2026-03',
	links: {
		publicRepoUrl: null,
		requestAccess: false,
	},
};

const featuredPaths: FeaturedPath[] = [
	{
		title: 'Practical Generative AI Workshops',
		description:
			'For leadership teams, operators, and organizations trying to move past vague AI enthusiasm into real understanding and usable workflow change.',
		bullets: [
			'How to think clearly about AI systems',
			'How to use AI as a teammate instead of a novelty',
			'Where current models help, fail, and mislead',
			'How to build better habits around prompting, review, and implementation',
		],
		href: '/workshops/',
		cta: 'See Workshops',
	},
	{
		title: 'Mímir',
		description:
			'A codebase topology and structural memory layer that gives AI systems a stable sense of place inside evolving software.',
		href: '/Mimir',
		cta: 'Explore Mímir',
	},
	{
		title: 'Selected Projects',
		description:
			'A portfolio of systems built across memory architecture, multimodal AI, orchestration, applied workflows, computer vision, and developer tooling.',
		href: '#selected-work',
		cta: 'Browse Projects',
	},
];

const excludedSlugs = new Set(['gauntlet-010', 'gauntlet-005', 'gauntlet001']);
const projects = (generatedProjects as ProjectCard[])
	.filter((project) => !excludedSlugs.has(project.slug))
	.sort((a, b) => a.name.localeCompare(b.name));
const bySlug = new Map(projects.map((project) => [project.slug, project]));
const homeBySlug = new Map<string, HomeProjectCard>([
	...projects.map((project) => [project.slug, project]),
	[mimirProjectCard.slug, mimirProjectCard],
]);

const selectedWorkSlugs = ['muninn', 'mimir', 'laila', 'friday', 'null-signal', 'pulsetrade'];
const selectedWork = selectedWorkSlugs
	.map((slug) => homeBySlug.get(slug))
	.filter((project): project is HomeProjectCard => Boolean(project));

const familyTree = familyTreeData as FamilyTreeConfig;
const branchesByFrom = new Map<string, FamilyTreeBranch[]>();
for (const branch of familyTree.branches) {
	if (!branchesByFrom.has(branch.from)) branchesByFrom.set(branch.from, []);
	branchesByFrom.get(branch.from)?.push(branch);
}
const specialBySlug = new Map(familyTree.specialNodes.map((node) => [node.slug, node]));

const spineRoleLabels = ['Origin', 'Turning Point', 'Next Gen'];
const usedTreeSlugs = new Set<string>();

function toIdPart(value: string): string {
	return value.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
}

function makeBranchId(fromSlug: string, label: string): string {
	return `branch-${toIdPart(fromSlug)}-${toIdPart(label)}`;
}

function projectHref(project: { slug: string; href?: string }): string {
	return project.href ?? `/projects/${project.slug}/`;
}

function buildTreeNode(slug: string, roleLabel?: string): FamilyTreeNodeView | null {
	if (usedTreeSlugs.has(slug)) return null;
	const project = homeBySlug.get(slug);
	if (!project) return null;

	usedTreeSlugs.add(slug);

	const branchGroups = (branchesByFrom.get(slug) || [])
		.map((branch) => {
			const nodes = branch.nodes
				.map((childSlug) => buildTreeNode(childSlug))
				.filter((node): node is FamilyTreeNodeView => Boolean(node));
			if (nodes.length === 0) return null;
			return {
				id: makeBranchId(slug, branch.label),
				label: branch.label,
				nodes,
			};
		})
		.filter((group): group is FamilyTreeBranchView => Boolean(group));

	return {
		project,
		roleLabel,
		special: specialBySlug.get(slug),
		branches: branchGroups,
	};
}

const spineNodes = familyTree.spine
	.map((slug, index) => buildTreeNode(slug, spineRoleLabels[index] || 'Stage'))
	.filter((node): node is FamilyTreeNodeView => Boolean(node));

if (spineNodes.length > 0) {
	const unplacedNodes = [...homeBySlug.values()]
		.filter((project) => !usedTreeSlugs.has(project.slug))
		.map((project) => buildTreeNode(project.slug))
		.filter((node): node is FamilyTreeNodeView => Boolean(node));

	if (unplacedNodes.length > 0) {
		spineNodes[spineNodes.length - 1].branches.push({
			id: makeBranchId(spineNodes[spineNodes.length - 1].project.slug, 'Additional explorations'),
			label: 'Additional explorations',
			nodes: unplacedNodes,
		});
	}
}

const statusOrder: ProjectCard['status'][] = ['Core', 'Experimental', 'Commission', 'Stub'];
const groupedByStatus = statusOrder
	.map((status) => ({
		status,
		items: projects.filter((project) => project.status === status),
	}))
	.filter((group) => group.items.length > 0);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<div class="page-shell">
			<header class="main-nav">
				<nav class="container nav-inner" aria-label="Primary">
					<a href="/" class="brand">austontatious.dev</a>
					<div class="nav-links nav-links-primary">
						<a href="/" aria-current="page">Home</a>
						<a href="/workshops/">Workshops</a>
						<a href="/Mimir">Mímir</a>
						<a href="https://github.com/austontatious" target="_blank" rel="noreferrer">GitHub</a>
						<a href="mailto:auston.horras@gmail.com">Contact</a>
					</div>
				</nav>
			</header>

			<main>
				<section id="hero" class="section hero home-hero">
					<FlowField variant="hero" />
					<div class="container section-inner">
						<p class="eyebrow">Calm systems for high-stakes decisions</p>
						<h1>I build AI systems that turn uncertainty into clear outcomes.</h1>
						<div class="hero-cta-row">
							<a class="button button-primary" href="/workshops/">Practical AI Workshops</a>
							<a class="button button-secondary" href="/Mimir">Explore Mímir</a>
						</div>
						<a class="hero-tertiary-link" href="#selected-work">Browse projects</a>
					</div>
				</section>

				<section class="section">
					<div class="container section-inner">
						<h2>Featured paths</h2>
						<p class="home-section-copy">The three most important doors on this site.</p>
						<div class="featured-path-grid">
							{featuredPaths.map((path) => (
								<article class="featured-path-card">
									<h3>{path.title}</h3>
									<p>{path.description}</p>
									{path.bullets && (
										<ul>
											{path.bullets.map((item) => <li>{item}</li>)}
										</ul>
									)}
									<a class="button button-secondary" href={path.href}>{path.cta}</a>
								</article>
							))}
						</div>
					</div>
				</section>

				<section class="section">
					<div class="container section-inner">
						<div class="home-identity-panel">
							<h2>Built from the operator side, not just the slide deck side</h2>
							<p>
								Senior Systems &amp; Applied AI Engineer building reliable automation, local-first AI platforms, memory architectures, and production-minded developer tooling. I come from healthcare, operations, and hands-on systems building, so the standard is practical usefulness under real constraints.
							</p>
							<p class="home-capability-line">
								Core capabilities: agent systems, memory infrastructure, multimodal pipelines, workflow automation, and production-minded tooling.
							</p>
						</div>
					</div>
				</section>

				<section id="selected-work" class="section">
					<div class="container section-inner">
						<h2>Selected work</h2>
						<p class="home-section-copy">
							These projects span agent systems, memory layers, multimodal pipelines, distributed tooling, and applied AI interfaces. Together they show the through-line in my work: systems that stay grounded, stateful, and usable.
						</p>
						<div class="selected-work-grid">
							{selectedWork.map((project) => (
								<article class="project-row selected-work-card">
									<div class="project-row-head">
										<a class="project-row-name" href={projectHref(project)}>{project.name}</a>
										<div class="project-row-badges">
											<span class="badge">{project.tag}</span>
											<span class="badge">{project.status}</span>
										</div>
									</div>
									<p class="project-row-desc">{project.shortDesc}</p>
									<div class="project-row-meta">
										<span>Updated: {project.updatedAt.slice(0, 7)}</span>
										{project.links.publicRepoUrl && (
											<a href={project.links.publicRepoUrl} target="_blank" rel="noreferrer">GitHub</a>
										)}
									</div>
								</article>
							))}
						</div>
						<a class="workshop-link home-index-link" href="#project-index">Open full project index</a>
					</div>
				</section>

				<section id="project-index" class="section">
					<FlowField variant="echo" />
					<div class="container section-inner">
						<h2>How the work connects</h2>
						<p class="home-section-copy">
							The platform thread behind these projects spans memory systems, agent infrastructure, multimodal tools, and applied product experiments.
						</p>

						<div class="family-tree-shell">
							<ul class="family-spine-list" id="family-spine">
								{spineNodes.map((node) => <FamilyTreeNode node={node} depth={0} />)}
							</ul>
						</div>

						<h3 class="project-index-heading">Project index</h3>
						<p class="home-section-copy">
							The broader index shows the full portfolio across core systems, experiments, and commissioned applied competency work.
						</p>

						{
							groupedByStatus.map((group) => (
								<section class="status-group" id={`status-${group.status.toLowerCase()}`}>
									<h3>{group.status}</h3>
									<div class="projects-index-list">
										{group.items.map((project) => (
											<>
												<article class="project-row">
													<div class="project-row-head">
														<a class="project-row-name" href={projectHref(project)}>{project.name}</a>
														<div class="project-row-badges">
															<span class="badge">{project.tag}</span>
															<span class="badge">{project.status}</span>
															{project.links.requestAccess && <span class="badge">Access on request</span>}
														</div>
													</div>
													<p class="project-row-desc">{project.shortDesc}</p>
													<div class="project-row-meta">
														<span>Updated: {project.updatedAt.slice(0, 7)}</span>
														{project.links.publicRepoUrl && (
															<a href={project.links.publicRepoUrl} target="_blank" rel="noreferrer">GitHub</a>
														)}
													</div>
												</article>
												{group.status === 'Core' && project.slug === 'muninn' && (
													<article class="project-row">
														<div class="project-row-head">
															<a class="project-row-name" href={mimirProjectCard.href}>{mimirProjectCard.name}</a>
															<div class="project-row-badges">
																<span class="badge">{mimirProjectCard.tag}</span>
																<span class="badge">{mimirProjectCard.status}</span>
															</div>
														</div>
														<p class="project-row-desc">{mimirProjectCard.shortDesc}</p>
														<div class="project-row-meta">
															<span>Updated: {mimirProjectCard.updatedAt}</span>
														</div>
													</article>
												)}
											</>
										))}
									</div>
								</section>
							))
						}
					</div>
				</section>

				<section class="section">
					<div class="container section-inner">
						<div class="home-contact-panel">
							<h2>Interested in working together?</h2>
							<p>
								Whether you are looking for a practical AI workshop, want to talk through a system idea, or think Mímir points toward something worth building, I am open to serious conversations.
							</p>
							<div class="cta-actions">
								<a class="button button-primary" href="mailto:auston.horras@gmail.com">Contact</a>
								<a class="button button-secondary" href="/workshops/">Workshops</a>
								<a class="button button-secondary" href="/Mimir">Mímir</a>
							</div>
						</div>
					</div>
				</section>
			</main>

			<footer class="site-footer">
				<div class="container footer-inner">
					<p>Calm systems for clear outcomes.</p>
					<div class="footer-links">
						<a href="mailto:auston.horras@gmail.com">Contact</a>
						<a href="https://www.linkedin.com/in/auston-horras-17022614/" target="_blank" rel="noreferrer">LinkedIn</a>
						<a href="https://github.com/austontatious" target="_blank" rel="noreferrer">GitHub</a>
					</div>
				</div>
			</footer>
		</div>
	</body>
</html>
